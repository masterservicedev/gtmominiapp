# Copy to .env.local and fill in. See Project Files/02_ENVIRONMENT_VARIABLES.md

DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/gtmo?sslmode=require
TELEGRAM_BOT_TOKEN=your_mini_app_bot_token_here
TELEGRAM_BOT_SECRET=your_webhook_secret_here

CHATWOOT_BASE_URL=https://chat.workspacegtmo.com
CHATWOOT_API_TOKEN=your_chatwoot_api_token
CHATWOOT_MINIAPP_INBOX_ID=your_inbox_id_number
CHATWOOT_ACCOUNT_ID=1

VOLUUM_POSTBACK_URL=https://t.voluum.com/postback

NEXT_PUBLIC_BOT_USERNAME=YourMiniAppBot
NEXT_PUBLIC_CHANNEL_LINK=https://t.me/your_channel
# MP4 URL for ad1/ad2 video offer (Telegram WebView-friendly HTTPS)
NEXT_PUBLIC_FUNNEL_VIDEO_URL=
# ad4 GTMO Code landing: video + optional media base for testimonial / Mo photos (no trailing slash)
NEXT_PUBLIC_GTMO_CODE_VIDEO_URL=
NEXT_PUBLIC_GTMO_CODE_MEDIA_BASE=
# Optional: forward REGISTER form leads server-side (never expose token to the client)
GOOGLE_SHEETS_WEBHOOK_URL=
WEBHOOK_LEAD_SECURITY_TOKEN=

# When `offers` has no active rows and user has no sticky variant / start_param, use this (default ad4 in code if unset).
FUNNEL_FALLBACK_VARIANT=ad4

ANALYTICS_SECRET=long_random_string_for_dashboard_auth
