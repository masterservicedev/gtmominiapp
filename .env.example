# Copy to .env.local and fill in. See Project Files/02_ENVIRONMENT_VARIABLES.md

DATABASE_URL=postgresql://user:password@ep-xxx.neon.tech/gtmo?sslmode=require
TELEGRAM_BOT_TOKEN=your_mini_app_bot_token_here
TELEGRAM_BOT_SECRET=your_webhook_secret_here

CHATWOOT_BASE_URL=https://chat.workspacegtmo.com
CHATWOOT_API_TOKEN=your_chatwoot_api_token
CHATWOOT_ACCOUNT_ID=1
# Mini App bot inbox id (optional — narrows which Chatwoot thread gets labels after handoff)
CHATWOOT_MINIAPP_INBOX_ID=
# Team ID for assign on qualified handoff (Chatwoot → Teams)
CHATWOOT_CLOSERS_TEAM_ID=

VOLUUM_POSTBACK_URL=https://t.voluum.com/postback

NEXT_PUBLIC_BOT_USERNAME=YourMiniAppBot
NEXT_PUBLIC_CHANNEL_LINK=https://t.me/your_channel
# MP4 or HLS URL for ad1/ad2 video offer (Telegram WebView-friendly HTTPS)
NEXT_PUBLIC_FUNNEL_VIDEO_URL=https://vz-f212c83f-59e.b-cdn.net/5f91f067-8d2a-4432-adee-1262dd90a73a/playlist.m3u8
# ad4 GTMO Signals landing: video + optional media base for testimonial / Mo photos (no trailing slash)
NEXT_PUBLIC_GTMO_CODE_VIDEO_URL=https://vz-f212c83f-59e.b-cdn.net/5f91f067-8d2a-4432-adee-1262dd90a73a/playlist.m3u8
# Optional: ad5 code_landing creative uses its own URL when set; otherwise falls back to GTMO_CODE / FUNNEL video above.
# NEXT_PUBLIC_GTMO_AD5_VIDEO_URL=
NEXT_PUBLIC_GTMO_CODE_MEDIA_BASE=
# Optional: forward REGISTER form leads server-side (never expose token to the client)
GOOGLE_SHEETS_WEBHOOK_URL=
WEBHOOK_LEAD_SECURITY_TOKEN=

# When `offers` has no active rows: everyone gets this funnel (sticky user variant is ignored until offers exist again).
FUNNEL_FALLBACK_VARIANT=ad4

ANALYTICS_SECRET=long_random_string_for_dashboard_auth
ADMIN_SECRET=long_random_string_for_admin_dashboard_auth

# Re-engagement A/B/C: `a_only` forces variant A; omit or `random` for A/B/C rotation.
# RE_ENGAGEMENT_VARIANT_MODE=a_only
