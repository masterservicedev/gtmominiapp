{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "noEmit": true,
    "baseUrl": "..",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "./**/*.ts",
    "../lib/db/schema.ts",
    "../lib/db/index.ts",
    "../lib/leadCardContent.ts",
    "../lib/productMatch.ts",
    "../lib/scoring.ts",
    "../lib/handoffHighIntent.ts",
    "../lib/chatwoot.ts",
    "../lib/telegramBotApi.ts",
    "../lib/voluum.ts"
  ]
}
